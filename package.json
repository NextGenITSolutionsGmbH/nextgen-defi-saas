    "test:e2e:local": "bash scripts/test-e2e.sh",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.51.1",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "bullmq": "^5.71.1",
    "ioredis": "^5.10.1",
    "server-only": "^0.0.1"
  }
