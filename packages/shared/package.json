{
  "name": "@defi-tracker/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    },
    "./abis": {
      "types": "./src/abis/index.ts",
      "default": "./src/abis/index.ts"
    },
    "./queue": {
      "types": "./src/queue/index.ts",
      "default": "./src/queue/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "type-check": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src/",
    "test:unit": "vitest run",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "ioredis": "^5.10.1"
  }
}
